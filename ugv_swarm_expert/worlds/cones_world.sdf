<?xml version="1.0" ?>
<!--
  UGV Swarm Formation Control – Obstacle Course World (7 Traffic Cones)
  Compatible with Gazebo 11 Classic + ROS 2 Humble

  Cone positions were generated to satisfy both constraints:
    (1) All pairwise cone distances  >= 1.5 m
    (2) All cones >= 1.5 m from every robot spawn point:
          leader (0.0,  0.0), tb3_1 (-0.7, 0.0), tb3_2 (-1.4, 0.0)

  Verified distances (all > 1.5 m):
    Cone positions (x, y):
      C1 = ( 2.5,  0.0)   C2 = ( 1.5,  2.0)   C3 = (-0.5,  2.5)
      C4 = (-2.5,  1.5)   C5 = (-3.0, -0.5)   C6 = (-1.0, -2.5)
      C7 = ( 1.5, -2.0)

    Minimum inter-cone distance: C1-C2 = C1-C7 = sqrt(5) ≈ 2.24 m  (> 1.5 m ✓)
    Minimum robot-cone distance: C6 ↔ tb3_2 (-1.4, 0) = sqrt(0.16+6.25) ≈ 2.53 m  (> 1.5 m ✓)

  Each cone: static orange cylinder Ø 0.20 m × 0.35 m tall
             sits on the ground (pose z = height/2 = 0.175 m)
-->
<sdf version="1.7">
  <world name="cones_world">

    <!-- ═══════════════════════════════════════════════
         Physics – identical to empty_world
         ═══════════════════════════════════════════════ -->
    <physics name="ode_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <gravity>0 0 -9.8</gravity>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <precon_iters>0</precon_iters>
          <sor>1.4</sor>
          <use_dynamic_moi_rescaling>1</use_dynamic_moi_rescaling>
        </solver>
        <constraints>
          <cfm>0.00001</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>2000.0</contact_max_correcting_vel>
          <contact_surface_layer>0.01</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <!-- Scene -->
    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>true</shadows>
      <grid>false</grid>
      <origin_visual>false</origin_visual>
    </scene>

    <!-- Lighting -->
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>1.0 1.0 1.0 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Ground Plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>100</mu>
                <mu2>50</mu2>
              </ode>
              <torsional><ode/></torsional>
            </friction>
            <contact><ode/></contact>
            <bounce/>
          </surface>
          <max_contacts>10</max_contacts>
        </collision>
        <visual name="visual">
          <cast_shadows>false</cast_shadows>
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Grey</name>
            </script>
          </material>
        </visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════
         Traffic Cone Helper Macro (inlined × 7)
         Each cone: static, Ø 0.20 m, height 0.35 m
         Orange body + light-grey base ring
         ═══════════════════════════════════════════════ -->

    <!-- Cone 1 – ( 2.5,  0.0) -->
    <model name="obstacle_cone_1">
      <static>true</static>
      <pose>2.5 0.0 0.175 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder><radius>0.10</radius><length>0.35</length></cylinder>
          </geometry>
          <surface>
            <friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction>
          </surface>
        </collision>
        <!-- Orange cone body -->
        <visual name="body">
          <geometry>
            <cylinder><radius>0.10</radius><length>0.32</length></cylinder>
          </geometry>
          <material>
            <ambient>1.0 0.27 0.0 1</ambient>
            <diffuse>1.0 0.27 0.0 1</diffuse>
            <specular>0.3 0.15 0.0 1</specular>
            <emissive>0.0 0.0 0.0 1</emissive>
          </material>
        </visual>
        <!-- White reflective stripe -->
        <visual name="stripe">
          <pose>0 0 0.06 0 0 0</pose>
          <geometry>
            <cylinder><radius>0.102</radius><length>0.06</length></cylinder>
          </geometry>
          <material>
            <ambient>0.95 0.95 0.95 1</ambient>
            <diffuse>0.95 0.95 0.95 1</diffuse>
          </material>
        </visual>
        <!-- Grey base plate -->
        <visual name="base">
          <pose>0 0 -0.16 0 0 0</pose>
          <geometry>
            <cylinder><radius>0.15</radius><length>0.03</length></cylinder>
          </geometry>
          <material>
            <ambient>0.5 0.5 0.5 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Cone 2 – ( 1.5,  2.0) -->
    <model name="obstacle_cone_2">
      <static>true</static>
      <pose>1.5 2.0 0.175 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder><radius>0.10</radius><length>0.35</length></cylinder>
          </geometry>
          <surface>
            <friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="body">
          <geometry>
            <cylinder><radius>0.10</radius><length>0.32</length></cylinder>
          </geometry>
          <material>
            <ambient>1.0 0.27 0.0 1</ambient>
            <diffuse>1.0 0.27 0.0 1</diffuse>
            <specular>0.3 0.15 0.0 1</specular>
            <emissive>0.0 0.0 0.0 1</emissive>
          </material>
        </visual>
        <visual name="stripe">
          <pose>0 0 0.06 0 0 0</pose>
          <geometry>
            <cylinder><radius>0.102</radius><length>0.06</length></cylinder>
          </geometry>
          <material>
            <ambient>0.95 0.95 0.95 1</ambient>
            <diffuse>0.95 0.95 0.95 1</diffuse>
          </material>
        </visual>
        <visual name="base">
          <pose>0 0 -0.16 0 0 0</pose>
          <geometry>
            <cylinder><radius>0.15</radius><length>0.03</length></cylinder>
          </geometry>
          <material>
            <ambient>0.5 0.5 0.5 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Cone 3 – (-0.5,  2.5) -->
    <model name="obstacle_cone_3">
      <static>true</static>
      <pose>-0.5 2.5 0.175 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder><radius>0.10</radius><length>0.35</length></cylinder>
          </geometry>
          <surface>
            <friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction>
