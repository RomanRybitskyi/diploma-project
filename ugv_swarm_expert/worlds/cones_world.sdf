            <diffuse>0.5 0.5 0.5 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Cone 5 – (-3.0, -0.5) -->
    <model name="obstacle_cone_5">
      <static>true</static>
      <pose>-3.0 -0.5 0.175 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder><radius>0.10</radius><length>0.35</length></cylinder>
          </geometry>
          <surface>
