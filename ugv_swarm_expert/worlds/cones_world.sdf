        </visual>
        <visual name="base">
          <pose>0 0 -0.16 0 0 0</pose>
          <geometry>
            <cylinder><radius>0.15</radius><length>0.03</length></cylinder>
          </geometry>
          <material>
            <ambient>0.5 0.5 0.5 1</ambient>
            <diffuse>0.5 0.5 0.5 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Cone 4 – (-2.5,  1.5) -->
    <model name="obstacle_cone_4">
      <static>true</static>
      <pose>-2.5 1.5 0.175 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder><radius>0.10</radius><length>0.35</length></cylinder>
          </geometry>
          <surface>
            <friction><ode><mu>0.8</mu><mu2>0.8</mu2></ode></friction>
          </surface>
        </collision>
        <visual name="body">
          <geometry>
            <cylinder><radius>0.10</radius><length>0.32</length></cylinder>
          </geometry>
          <material>
            <ambient>1.0 0.27 0.0 1</ambient>
            <diffuse>1.0 0.27 0.0 1</diffuse>
            <specular>0.3 0.15 0.0 1</specular>
            <emissive>0.0 0.0 0.0 1</emissive>
          </material>
